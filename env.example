# Convex client URL used by the React app.
VITE_CONVEX_URL=https://convex.hookedcue.com

# Convex HTTP/site URL used by Better Auth.
VITE_CONVEX_SITE_URL=https://convexdash.hookedcue.com

# Server-side Convex/Better Auth settings.
CONVEX_SITE_URL=https://convexdash.hookedcue.com
SITE_URL=https://app.hookedcue.com

# Optional for Convex Cloud only: set this to the real deployment value from Convex.
# Do not use a custom domain label such as hookedcue here; it will break `npx convex dev`.
# CONVEX_DEPLOYMENT=prod:<your-convex-deployment-name>

# Optional for self-hosted/custom Convex CLI usage:
# CONVEX_SELF_HOSTED_URL=https://convex.hookedcue.com
# CONVEX_SELF_HOSTED_ADMIN_KEY=<your-self-hosted-admin-key>
